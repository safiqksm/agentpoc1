# Copy to .env — never commit .env

# Entra ID — tenant
TENANT_ID=<your-entra-tenant-id>

# CORS — React dev server origin
ALLOWED_ORIGIN=http://localhost:5173

# MCP Server — set to local MCP server to bypass in-process mock
# Leave blank to use in-process mock (no MCP server process needed)
MCP_SERVER_URL=http://localhost:9000

# Azure OpenAI — local dev (replaced by Managed Identity in Azure)
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_KEY=<your-api-key>
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-08-01-preview

# STEP 4 — OBO token exchange (see ENTRA_OBO_SETUP.md)
# Leave blank to skip OBO and use the original token (local dev mode)
AGENT_CLIENT_ID=<agentpoc1-agent application client ID>   # same as AGENT_APP_ID in Entra portal
AGENT_CLIENT_SECRET=<client secret from agentpoc1-agent>
MCP_APP_ID=<agentpoc1-mcp application client ID>
